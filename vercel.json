{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "grace.oryva.site" }],
      "destination": "/grace/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "belvidere.oryva.site" }],
      "destination": "/belvidere/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "driandennis.oryva.site" }],
      "destination": "/driandennis/:path*"
    }
  ]
}
